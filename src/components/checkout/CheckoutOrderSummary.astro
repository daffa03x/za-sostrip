---
import type { EventDetail, EventTicket } from '../../data/events';

interface Props {
	event: EventDetail;
	selectedTicket: EventTicket;
}

const { event, selectedTicket } = Astro.props;
---

<section class="rounded-2xl border border-outline-variant/40 bg-white shadow-[0_8px_24px_-12px_rgba(80,67,78,0.35)] overflow-hidden" data-reveal>
	<div class="relative h-[120px]">
		<img
			alt={event.imageAlt}
			class="absolute inset-0 h-full w-full object-cover"
			src={event.image}
			draggable="false"
		/>
		<div class="absolute inset-0 bg-gradient-to-b from-black/20 to-primary/70"></div>
		<div class="absolute inset-x-0 bottom-0 px-md pb-md">
			<span class="rounded-full bg-white/20 px-2 py-0.5 text-[10px] font-bold uppercase tracking-[0.08em] text-white backdrop-blur-md">
				{event.category}
			</span>
			<h2 class="mt-1 font-headline-md text-[18px] font-black leading-tight text-white">{event.title}</h2>
		</div>
	</div>

	<div class="p-md">
		<div class="space-y-sm">
			<div class="flex items-center gap-sm text-on-surface">
				<span class="material-symbols-outlined mt-0.5 text-[18px] text-primary" data-icon="calendar_today">calendar_today</span>
				<div>
					<p class="text-[10px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">Tanggal</p>
					<p class="text-sm font-bold leading-tight">{event.date}</p>
				</div>
			</div>
			<div class="flex items-center gap-sm text-on-surface">
				<span class="material-symbols-outlined mt-0.5 text-[18px] text-primary" data-icon="location_on">location_on</span>
				<div>
					<p class="text-[10px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">Lokasi</p>
					<p class="text-sm font-bold leading-tight">{event.venue}, {event.location}</p>
				</div>
			</div>
		</div>

		<div class="mt-md rounded-xl border border-outline-variant/40 bg-surface-container-low p-sm">
			<div class="flex items-start justify-between gap-sm">
				<div class="flex-1">
					<p class="text-[10px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">Tiket dipilih</p>
					<p class="mt-0.5 text-sm font-black leading-tight text-on-surface">{selectedTicket.name}</p>
					<p class="mt-0.5 text-body-sm text-on-surface-variant">{selectedTicket.description}</p>
				</div>
				<span class="shrink-0 text-sm font-black text-primary">{selectedTicket.priceLabel}</span>
			</div>
		</div>
	</div>
</section>