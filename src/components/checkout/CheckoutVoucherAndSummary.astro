---
---

<div class="rounded-2xl bg-surface-container-low p-md" data-reveal-scope>
	<h2 class="mb-sm font-title-md text-title-md text-on-surface" data-reveal>Kode Voucher</h2>

	<div class="flex gap-xs" data-reveal>
		<input
			id="voucher-input"
			type="text"
			placeholder="Masukkan kode voucher"
			class="flex-1 rounded-xl border border-outline-variant bg-surface px-sm py-xs text-sm uppercase tracking-widest focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary"
			aria-label="Kode voucher"
		/>
		<button
			id="voucher-apply-btn"
			type="button"
			class="rounded-xl bg-secondary px-md py-xs text-sm font-black text-on-secondary disabled:opacity-50"
		>
			Pakai
		</button>
	</div>

	<p id="voucher-msg" class="mt-xs hidden text-sm" aria-live="polite"></p>
</div>

<script>
	const setup = () => {
		const btn = document.getElementById('voucher-apply-btn');
		const input = document.getElementById('voucher-input');
		const msg = document.getElementById('voucher-msg');
		const form = document.querySelector('[data-checkout-form]');

		if (!btn || !input || !msg || !(form instanceof HTMLElement)) return;
		if (btn.dataset.voucherReady === 'true') return;
		btn.dataset.voucherReady = 'true';

		const backendUrl = (form.dataset.backendUrl ?? '').replace(/\/$/, '');

		const showMsg = (text: string, ok: boolean) => {
			msg.textContent = text;
			msg.className = `mt-xs text-sm ${ok ? 'text-success' : 'text-error'}`;
		};

		btn.addEventListener('click', async () => {
			const code = (input as HTMLInputElement).value.trim().toUpperCase();
			if (!code) { showMsg('Masukkan kode voucher terlebih dahulu.', false); return; }

			const eventId = form.dataset.eventId ?? '';
			const qtyInput = form.querySelector<HTMLInputElement>('[data-qty-input]');
			const jumlahTiket = parseInt(qtyInput?.value ?? '1', 10);

			btn.setAttribute('disabled', 'true');
			btn.textContent = 'Mengecek…';

			try {
				const res = await fetch(`${backendUrl}/api/voucher/validate`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify({ code, event_id: Number(eventId), jumlah_tiket: jumlahTiket }),
				});
				const data = await res.json() as { valid?: boolean; discount_per_ticket?: number; message?: string };

				if (!res.ok || !data.valid) {
					showMsg(data.message ?? 'Kode voucher tidak valid.', false);
				} else {
					showMsg(`Voucher berhasil! Diskon Rp ${(data.discount_per_ticket ?? 0).toLocaleString('id-ID')} per tiket.`, true);
					document.dispatchEvent(new CustomEvent('checkout:voucher-applied', {
						detail: { discount_per_ticket: data.discount_per_ticket ?? 0, code },
					}));
					(input as HTMLInputElement).disabled = true;
					btn.textContent = 'Terpakai';
					return;
				}
			} catch {
				showMsg('Gagal menghubungi server. Coba lagi.', false);
			}

			btn.removeAttribute('disabled');
			btn.textContent = 'Pakai';
		});
	};

	setup();
	document.addEventListener('astro:page-load', setup);
</script>
