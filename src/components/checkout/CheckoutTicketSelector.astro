<section data-reveal-scope>
	<div class="rounded-2xl border border-outline-variant/40 bg-white p-md shadow-[0_6px_18px_-14px_rgba(80,67,78,0.35)]" data-reveal>
		<div class="flex items-center justify-between">
			<div>
				<p class="text-[11px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">Jumlah tiket</p>
				<p class="mt-0.5 text-body-sm text-on-surface-variant">Maks. 3 tiket per transaksi</p>
			</div>
			<div class="flex items-center gap-sm">
				<button
					type="button"
					class="flex h-9 w-9 items-center justify-center rounded-full border border-outline-variant bg-surface-container-low text-on-surface transition-all active:scale-90 disabled:opacity-40"
					aria-label="Kurangi jumlah tiket"
					data-qty-minus
				>
					<span class="material-symbols-outlined text-[20px]" data-icon="remove">remove</span>
				</button>
				<span class="w-6 text-center text-base font-black text-on-surface" data-qty-display>1</span>
				<button
					type="button"
					class="flex h-9 w-9 items-center justify-center rounded-full border border-primary bg-primary-container/20 text-primary transition-all active:scale-90 disabled:opacity-40"
					aria-label="Tambah jumlah tiket"
					data-qty-plus
				>
					<span class="material-symbols-outlined text-[20px]" data-icon="add">add</span>
				</button>
			</div>
		</div>
		<input type="hidden" name="quantity" value="1" data-qty-value />
	</div>
</section>

<script>
	const setupQty = () => {
		const minusBtn = document.querySelector('[data-qty-minus]');
		const plusBtn = document.querySelector('[data-qty-plus]');
		const display = document.querySelector('[data-qty-display]');
		const hiddenInput = document.querySelector('[data-qty-value]');

		if (
			!(minusBtn instanceof HTMLButtonElement) ||
			!(plusBtn instanceof HTMLButtonElement) ||
			!(display instanceof HTMLElement) ||
			!(hiddenInput instanceof HTMLInputElement)
		) return;

		const MIN = 1;
		const MAX = 3;
		let qty = 1;

		const updateQty = (newQty: number) => {
			qty = Math.min(MAX, Math.max(MIN, newQty));
			display.textContent = String(qty);
			hiddenInput.value = String(qty);
			(minusBtn as HTMLButtonElement).disabled = qty <= MIN;
			(plusBtn as HTMLButtonElement).disabled = qty >= MAX;

			// Notify other components
			document.dispatchEvent(new CustomEvent('checkout:qty-change', { detail: { qty } }));
		};

		minusBtn.addEventListener('click', () => updateQty(qty - 1));
		plusBtn.addEventListener('click', () => updateQty(qty + 1));

		// Init
		updateQty(1);
	};

	setupQty();
	document.addEventListener('astro:page-load', setupQty);
</script>
