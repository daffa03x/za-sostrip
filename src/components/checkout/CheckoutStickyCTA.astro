---
import type { EventDetail } from '../../data/events';

interface Props {
	event: EventDetail;
}

const { event } = Astro.props;
---

<div
	class="fixed bottom-[60px] left-1/2 z-40 w-full max-w-[430px] -translate-x-1/2 border-t border-outline-variant/30 bg-white/90 px-gutter py-sm shadow-[0_-8px_24px_-18px_rgba(80,67,78,0.8)] backdrop-blur-md"
	data-checkout-sticky
>
	<div class="flex items-center justify-between gap-sm">
		<div>
			<p class="text-[10px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">Total bayar</p>
			<p class="text-sm font-black leading-tight text-primary" data-sticky-total>
				{event.tickets[0]?.priceLabel ?? 'Harga menyusul'}
			</p>
		</div>
		<button
			class="cta-glow flex min-h-11 flex-1 items-center justify-center gap-xs rounded-full bg-primary px-md text-sm font-black text-white shadow-[0_10px_20px_-12px_rgba(125,41,127,0.9)] transition-all active:scale-[0.98] disabled:opacity-60 disabled:pointer-events-none"
			type="submit"
			form="checkout-form"
			data-checkout-submit
		>
			<span class="material-symbols-outlined text-[18px]" data-icon="payment">payment</span>
			Lanjut Bayar
		</button>
	</div>
</div>