---
import LoadingState from '../ui/LoadingState.astro';
---

<div data-reveal-scope>
	<div
		class="rounded-2xl border border-outline-variant/40 bg-white p-md shadow-[0_6px_18px_-14px_rgba(80,67,78,0.35)]"
		data-reveal
	>
		<div class="flex items-start justify-between gap-sm">
			<div class="min-w-0 flex-1">
				<p class="text-[10px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">Metode pembayaran</p>
				<h2 class="mt-0.5 font-title-md text-title-md text-on-surface">Pilih kanal bayar</h2>
				<div class="mt-xs" data-payment-summary>
					<LoadingState label="Memuat metode pembayaran..." variant="inline" size="sm" class="justify-start" />
				</div>
			</div>
			<button
				type="button"
				class="inline-flex shrink-0 items-center gap-xs rounded-full bg-primary px-sm py-xs text-xs font-black text-white shadow-[0_8px_18px_-12px_rgba(125,41,127,0.8)]"
				data-open-modal="payment"
			>
				<span class="material-symbols-outlined text-[16px]" data-icon="payments">payments</span>
				Pilih
			</button>
		</div>
	</div>

	<div
		class="fixed inset-0 z-50 hidden px-gutter py-lg"
		data-modal="payment"
		aria-hidden="true"
		role="dialog"
		aria-modal="true"
		aria-labelledby="payment-modal-title"
	>
		<button
			type="button"
			class="absolute inset-0 h-full w-full bg-black/45"
			data-close-modal="payment"
			aria-label="Tutup modal metode pembayaran"
		></button>
		<div class="relative mx-auto flex max-h-[85vh] w-full max-w-[430px] flex-col overflow-hidden rounded-2xl bg-background shadow-[0_24px_80px_-32px_rgba(0,0,0,0.55)]">
			<div class="flex items-start justify-between gap-sm border-b border-outline-variant/30 bg-white px-md py-sm">
				<div>
					<p class="text-[10px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">Metode pembayaran</p>
					<h2 id="payment-modal-title" class="font-headline-md text-headline-md text-on-surface">Pilih kanal bayar</h2>
				</div>
				<button
					type="button"
					class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-surface-container-low text-on-surface-variant"
					data-close-modal="payment"
					aria-label="Tutup"
				>
					<span class="material-symbols-outlined text-[20px]" data-icon="close">close</span>
				</button>
			</div>

			<div class="space-y-md overflow-y-auto p-md" data-reveal-stagger data-pm-list>
				<LoadingState label="Memuat metode pembayaran..." variant="inline" size="sm" class="py-sm" />
			</div>

			<div class="flex gap-sm border-t border-outline-variant/30 bg-white px-md py-sm">
				<button
					type="button"
					class="flex min-h-11 flex-1 items-center justify-center rounded-full border border-outline-variant bg-white px-md text-sm font-black text-on-surface"
					data-close-modal="payment"
				>
					Nanti
				</button>
				<button
					type="button"
					class="flex min-h-11 flex-1 items-center justify-center rounded-full bg-primary px-md text-sm font-black text-white"
					data-confirm-payment-method
				>
					Pakai Metode Ini
				</button>
			</div>
		</div>
	</div>

	<template data-pm-group-tpl>
		<section class="space-y-sm" data-pm-group>
			<div class="flex items-center justify-between gap-sm">
				<h3 class="text-[11px] font-black uppercase tracking-[0.08em] text-on-surface-variant" data-pm-group-title></h3>
				<span class="rounded-full bg-surface-container-low px-2 py-0.5 text-[10px] font-bold text-on-surface-variant" data-pm-group-count></span>
			</div>
			<div class="space-y-sm" data-pm-group-items></div>
		</section>
	</template>

	<template data-pm-tpl>
		<label class="flex cursor-pointer items-center gap-sm rounded-xl border border-outline-variant bg-surface p-sm transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary-container/30">
			<input type="radio" name="payment_method_id" class="h-4 w-4 accent-primary" data-pm-radio />
			<img class="hidden h-6 w-auto max-w-[72px] object-contain" loading="lazy" data-pm-image data-bind-src="image" data-bind-alt="name" />
			<span class="flex-1 text-sm font-bold text-on-surface" data-bind="name"></span>
		</label>
	</template>
</div>

<script>
	const setupPaymentModal = () => {
		const modal = document.querySelector('[data-modal="payment"]');
		const summary = document.querySelector('[data-payment-summary]');

		if (!(modal instanceof HTMLElement) || !(summary instanceof HTMLElement)) return;
		if (modal.dataset.modalReady === 'true') return;
		modal.dataset.modalReady = 'true';

		const updateSummary = () => {
			const checked = document.querySelector<HTMLInputElement>('[data-pm-radio]:checked');
			const label = checked?.closest('label')?.querySelector<HTMLElement>('[data-bind="name"]')?.textContent?.trim();
			summary.textContent = label ? `Dipilih: ${label}` : 'Belum dipilih. Pilih metode pembayaran sebelum lanjut bayar.';
		};

		const openModal = () => {
			modal.classList.remove('hidden');
			modal.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden';
			window.setTimeout(() => {
				const checked = modal.querySelector<HTMLInputElement>('[data-pm-radio]:checked');
				const first = modal.querySelector<HTMLInputElement>('[data-pm-radio]');
				(checked ?? first)?.focus();
			}, 50);
		};

		const closeModal = () => {
			modal.classList.add('hidden');
			modal.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = '';
			updateSummary();
		};

		document.querySelectorAll('[data-open-modal="payment"]').forEach((btn) => {
			btn.addEventListener('click', openModal);
		});
		document.querySelectorAll('[data-close-modal="payment"]').forEach((btn) => {
			btn.addEventListener('click', closeModal);
		});
		document.querySelector('[data-confirm-payment-method]')?.addEventListener('click', () => {
			if (!document.querySelector('[data-pm-radio]:checked')) {
				window.toast.warning('Pilih metode pembayaran terlebih dahulu.', { title: 'Metode pembayaran' });
				return;
			}
			closeModal();
		});
		document.addEventListener('change', (e) => {
			if (e.target instanceof HTMLInputElement && e.target.matches('[data-pm-radio]')) updateSummary();
		});
		document.addEventListener('checkout:payment-methods-rendered', updateSummary);
		document.addEventListener('checkout:open-modal', (e) => {
			const detail = (e as CustomEvent<{ name: string }>).detail;
			if (detail.name === 'payment') openModal();
		});

		updateSummary();
	};

	setupPaymentModal();
	document.addEventListener('astro:page-load', setupPaymentModal);
</script>
