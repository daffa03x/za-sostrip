---
import type { EventDetail } from '../../data/events';

interface Props {
	event: EventDetail;
}

const { event } = Astro.props;
---

<a
	class="group flex gap-sm rounded-2xl border border-outline-variant/40 bg-white p-sm shadow-[0_6px_18px_-14px_rgba(80,67,78,0.35)] card-hover transition-all active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
	href={`/events/detail?slug=${event.slug}`}
	data-bind-href="href"
	aria-label={`Lihat detail ${event.title}`}
	data-event-list-card
	data-reveal
>
	<div class="relative h-[104px] w-[104px] shrink-0 overflow-hidden rounded-xl bg-surface-container-low">
		<img alt={event.imageAlt} data-bind-alt="imageAlt" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" src={event.image} data-bind-src="image" draggable="false" />
	</div>
	<div class="min-w-0 flex-1 py-1">
		<div class="mb-2 flex items-center justify-between gap-sm">
			<span class="rounded-full bg-primary-container px-2 py-1 text-[9px] font-black uppercase tracking-[0.08em] text-on-primary" data-bind="category">{event.category}</span>
			<span class="material-symbols-outlined text-[18px] text-primary" data-icon="chevron_right">chevron_right</span>
		</div>
		<h3 class="truncate text-[16px] font-black leading-tight text-on-surface" data-bind="title">{event.title}</h3>
		<div class="mt-2 space-y-1 text-on-surface-variant">
			<div class="flex items-center gap-1.5">
				<span class="material-symbols-outlined text-[16px] opacity-70" data-icon="calendar_today">calendar_today</span>
				<span class="truncate text-[11px] font-bold uppercase tracking-wide" data-bind="date">{event.date}</span>
			</div>
			<div class="flex items-center gap-1.5">
				<span class="material-symbols-outlined text-[16px] opacity-70" data-icon="location_on">location_on</span>
				<span class="truncate text-[11px]" data-bind="location">{event.location}</span>
			</div>
		</div>
	</div>
</a>
