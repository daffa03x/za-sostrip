---
const navItems = [
	{ label: 'Home', icon: 'home', href: '#', active: true },
	{ label: 'Event', icon: 'calendar_today', href: '#', active: false },
	{ label: 'Blog', icon: 'newspaper', href: '#', active: false },
	{ label: 'Akun', icon: 'person', href: '#', active: false },
];
---

<nav class="fixed bottom-0 left-1/2 w-full max-w-[430px] -translate-x-1/2 bg-white border-t border-surface-container-highest shadow-[0_-2px_10px_rgba(0,0,0,0.05)] px-gutter py-2 flex justify-between items-center z-50" aria-label="Navigasi utama" data-bottom-nav>
	{
		navItems.map((item) => (
			<a class:list={['flex flex-col items-center gap-1 flex-1 nav-item-active', item.active ? 'text-primary' : 'text-on-surface-variant']} href={item.href} aria-current={item.active ? 'page' : undefined}>
				<span class="material-symbols-outlined text-[24px]" style={item.active ? "font-variation-settings: 'FILL' 1;" : undefined}>
					{item.icon}
				</span>
				<span class="text-[10px] font-semibold">{item.label}</span>
			</a>
		))
	}
</nav>
