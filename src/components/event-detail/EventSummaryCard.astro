---
import type { EventDetail } from '../../data/events';

interface Props {
	event: EventDetail;
}

const { event } = Astro.props;
---

<section class="rounded-2xl border border-outline-variant/40 bg-white p-md shadow-[0_8px_24px_-12px_rgba(80,67,78,0.35)]" data-reveal>
	<div class="mb-md grid grid-cols-1 gap-sm">
		<div class="flex items-start gap-sm text-on-surface">
			<span class="material-symbols-outlined mt-0.5 text-[20px] text-primary" data-icon="calendar_today">calendar_today</span>
			<div>
				<p class="font-label-md text-label-md uppercase text-on-surface-variant">Tanggal</p>
				<p class="font-bold leading-tight">{event.date}</p>
			</div>
		</div>
		<div class="flex items-start gap-sm text-on-surface">
			<span class="material-symbols-outlined mt-0.5 text-[20px] text-primary" data-icon="location_on">location_on</span>
			<div>
				<p class="font-label-md text-label-md uppercase text-on-surface-variant">Lokasi</p>
				<p class="font-bold leading-tight">{event.location}</p>
			</div>
		</div>
	</div>

	<p class="text-body-sm text-on-surface-variant">{event.summary}</p>

	<div class="mt-md grid grid-cols-3 gap-sm" data-reveal-stagger>
		{
			event.stats.map((stat) => (
				<div class="rounded-xl bg-surface-container-low p-sm text-center" data-reveal="scale">
					<p class="text-[10px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">{stat.label}</p>
					<p class="mt-1 text-[12px] font-black leading-tight text-on-surface">{stat.value}</p>
				</div>
			))
		}
	</div>
</section>
