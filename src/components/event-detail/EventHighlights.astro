---
import type { EventDetail } from '../../data/events';

interface Props {
	event: EventDetail;
}

const { event } = Astro.props;
---

<section class={event.highlights.length ? '' : 'hidden'} data-reveal-scope data-highlights-section>
	<h2 class="mb-md font-headline-md text-headline-md text-on-background" data-reveal>Yang kamu dapat</h2>
	<!-- Semua benefit dalam SATU card. Grid 2 kolom di layar >=sm agar tinggi ke bawah berkurang
	     setengah ketika benefit banyak, sehingga tidak perlu scroll panjang. -->
	<div class="rounded-3xl border border-outline-variant/40 bg-surface-container-lowest p-md" data-reveal>
		<div class="grid grid-cols-1 gap-x-lg gap-y-sm sm:grid-cols-2" data-reveal-stagger data-highlights-list>
			{
				event.highlights.map((highlight) => (
					<div class="flex items-start gap-sm" data-reveal>
						<div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-container text-on-primary">
							<span class="material-symbols-outlined text-[16px]" data-icon="check">check</span>
						</div>
						<p class="text-body-sm text-on-surface-variant" data-bind="text">{highlight}</p>
					</div>
				))
			}
		</div>
		<template data-highlights-tpl>
			<div class="flex items-start gap-sm" data-reveal>
				<div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary-container text-on-primary">
					<span class="material-symbols-outlined text-[16px]" data-icon="check">check</span>
				</div>
				<p class="text-body-sm text-on-surface-variant" data-bind="text"></p>
			</div>
		</template>
	</div>
</section>
