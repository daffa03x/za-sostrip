---
import type { EventDetail } from '../../data/events';

interface Props {
	event: EventDetail;
}

const { event } = Astro.props;
---

<section class="relative overflow-hidden rounded-b-[40px] bg-primary text-white" data-reveal="fade">
	<img alt={event.imageAlt} data-bind-alt="imageAlt" data-cover-src class="block h-auto w-full" src={event.image} data-bind-src="image" draggable="false" />
	{/* Overlay gradient sekaligus tombol untuk membuka cover sebagai lightbox. z default (di bawah kontrol z-10). */}
	<button
		type="button"
		data-cover-trigger
		aria-label="Perbesar cover event"
		class="absolute inset-0 cursor-zoom-in bg-gradient-to-b from-black/35 via-primary/20 to-primary/75 transition-colors duration-200 hover:from-black/45 hover:to-primary/80 focus:outline-none focus-visible:ring-2 focus-visible:ring-inset focus-visible:ring-white/70"
	></button>
	<div class="pointer-events-none absolute bottom-14 right-gutter z-10 flex items-center gap-1.5 rounded-full bg-black/35 px-3 py-1.5 text-[11px] font-semibold text-white backdrop-blur-md animate-reveal delay-100">
		<span class="material-symbols-outlined text-[15px]" data-icon="zoom_in">zoom_in</span>
		<span>Ketuk untuk perbesar</span>
	</div>
	<header class="absolute inset-x-0 top-0 z-10 flex items-center justify-between px-gutter py-sm">
		<a
			class="flex h-10 w-10 items-center justify-center rounded-full border border-white/35 bg-white/20 text-white backdrop-blur-md transition-all active:scale-95"
			href="/"
			aria-label="Kembali ke beranda"
		>
			<span class="material-symbols-outlined text-[22px]" data-icon="arrow_back">arrow_back</span>
		</a>
		<button
			class="flex h-10 w-10 items-center justify-center rounded-full border border-white/35 bg-white/20 text-white backdrop-blur-md transition-all active:scale-95"
			type="button"
			aria-label={`Bagikan ${event.title}`}
			data-share-event
			data-share-title={event.title}
		>
			<span class="material-symbols-outlined text-[22px]" data-icon="ios_share">ios_share</span>
		</button>
	</header>
	<div class="absolute inset-x-0 bottom-0 z-10 px-gutter pb-14 animate-reveal delay-100">
		<div class="flex items-center gap-sm">
			<span class="rounded-full bg-white/20 px-3 py-1 text-[11px] font-bold uppercase tracking-[0.08em] text-white backdrop-blur-md" data-bind="category">{event.category}</span>
			<span class="rounded-full bg-white px-3 py-1 text-[11px] font-bold text-primary" data-bind="status">{event.status}</span>
		</div>
	</div>
</section>

{/* ── Lightbox cover event ───────────────────────────────────────────────── */}
<div
	id="cover-modal"
	class="fixed inset-0 z-[110] hidden"
	role="dialog"
	aria-modal="true"
	aria-label="Cover event"
>
	<div data-cover-backdrop class="absolute inset-0 bg-black/90 opacity-0 transition-opacity duration-300 ease-out"></div>
	<button
		type="button"
		data-cover-close
		aria-label="Tutup"
		class="absolute right-gutter top-sm z-10 flex h-10 w-10 items-center justify-center rounded-full border border-white/35 bg-white/20 text-white backdrop-blur-md transition active:scale-95"
	>
		<span class="material-symbols-outlined text-[22px]">close</span>
	</button>
	<div data-cover-dismiss class="absolute inset-0 flex items-center justify-center p-gutter">
		<img
			data-cover-image
			src=""
			alt=""
			draggable="false"
			class="max-h-full max-w-full scale-95 rounded-2xl object-contain opacity-0 shadow-2xl transition-all duration-300 ease-out"
		/>
	</div>
</div>

<style>
	#cover-modal[data-open='true'] [data-cover-backdrop] {
		opacity: 1;
	}

	#cover-modal[data-open='true'] [data-cover-image] {
		opacity: 1;
		transform: scale(1);
	}

	@media (prefers-reduced-motion: reduce) {
		#cover-modal [data-cover-backdrop],
		#cover-modal [data-cover-image] {
			transition: none;
		}
	}
</style>

<script>
	const setupCoverLightbox = () => {
		const trigger = document.querySelector('[data-cover-trigger]');
		const modal = document.getElementById('cover-modal');

		if (!(trigger instanceof HTMLButtonElement) || !modal) {
			return;
		}
		if (trigger.dataset.coverReady === 'true') {
			return;
		}
		trigger.dataset.coverReady = 'true';

		const source = document.querySelector('[data-cover-src]');
		const image = modal.querySelector('[data-cover-image]');
		const backdrop = modal.querySelector('[data-cover-backdrop]');
		const dismiss = modal.querySelector('[data-cover-dismiss]');
		const prefersReduced = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		let lastFocus: Element | null = null;

		const openModal = () => {
			// Ambil gambar terkini dari cover (src sudah diisi CSR berdasarkan data event).
			if (source instanceof HTMLImageElement && image instanceof HTMLImageElement) {
				image.src = source.currentSrc || source.src;
				image.alt = source.alt;
			}
			lastFocus = document.activeElement;
			modal.classList.remove('hidden');
			document.body.style.overflow = 'hidden';
			requestAnimationFrame(() => {
				modal.dataset.open = 'true';
			});
		};

		const closeModal = () => {
			modal.dataset.open = 'false';
			document.body.style.overflow = '';
			const finish = () => modal.classList.add('hidden');
			if (prefersReduced()) {
				finish();
			} else {
				window.setTimeout(finish, 300);
			}
			if (lastFocus instanceof HTMLElement) {
				lastFocus.focus();
			}
		};

		trigger.addEventListener('click', openModal);
		backdrop?.addEventListener('click', closeModal);
		// Klik area kosong (bukan gambar) menutup modal.
		dismiss?.addEventListener('click', (e) => {
			if (e.target === dismiss) closeModal();
		});
		modal.querySelectorAll('[data-cover-close]').forEach((btn) => btn.addEventListener('click', closeModal));
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && modal.dataset.open === 'true') {
				closeModal();
			}
		});
	};

	setupCoverLightbox();
	document.addEventListener('astro:page-load', setupCoverLightbox);
</script>

{/* ── Modal bagikan event (bottom sheet) ─────────────────────────────────── */}
<div
	id="share-modal"
	class="fixed inset-0 z-[100] hidden"
	role="dialog"
	aria-modal="true"
	aria-labelledby="share-modal-title"
