					</span>
					<span class="text-[11px] font-medium text-on-surface-variant transition-colors group-hover:text-on-surface">WhatsApp</span>
				</button>

				<button type="button" data-share-target="instagram" class="group flex flex-col items-center gap-1.5">
					<span class="flex h-14 w-14 items-center justify-center rounded-full bg-gradient-to-br from-[#feda75] via-[#d62976] to-[#4f5bd5] text-white shadow-sm transition-all duration-200 group-hover:-translate-y-0.5 group-hover:shadow-md group-hover:brightness-105 group-active:scale-90">
