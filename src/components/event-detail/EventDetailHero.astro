					</span>
					<span class="text-[11px] font-medium text-on-surface-variant transition-colors group-hover:text-on-surface">Instagram</span>
				</button>

				<button type="button" data-share-target="tiktok" class="group flex flex-col items-center gap-1.5">
					<span class="flex h-14 w-14 items-center justify-center rounded-full bg-black text-white shadow-sm transition-all duration-200 group-hover:-translate-y-0.5 group-hover:shadow-md group-hover:brightness-105 group-active:scale-90">
						<svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" aria-hidden="true"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
					</span>
					<span class="text-[11px] font-medium text-on-surface-variant transition-colors group-hover:text-on-surface">TikTok</span>
				</button>

				<button type="button" data-share-target="facebook" class="group flex flex-col items-center gap-1.5">
					<span class="flex h-14 w-14 items-center justify-center rounded-full bg-[#1877F2] text-white shadow-sm transition-all duration-200 group-hover:-translate-y-0.5 group-hover:shadow-md group-hover:brightness-105 group-active:scale-90">
						<svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
					</span>
					<span class="text-[11px] font-medium text-on-surface-variant transition-colors group-hover:text-on-surface">Facebook</span>
				</button>
			</div>

			{/* Salin link */}
			<div class="flex items-center gap-2 rounded-2xl border border-outline-variant/50 bg-surface-container-low py-2 pl-4 pr-2 focus-within:border-primary">
				<span class="material-symbols-outlined shrink-0 text-[20px] text-on-surface-variant">link</span>
				<input
					data-share-link
					type="text"
					readonly
					value=""
					aria-label="Link event"
					class="min-w-0 flex-1 truncate border-0 bg-transparent p-0 text-sm text-on-surface-variant shadow-none focus:border-0 focus:outline-none focus:ring-0"
				/>
				<button
					type="button"
					data-share-copy
					class="flex shrink-0 items-center gap-xs rounded-xl bg-primary px-4 py-2 text-sm font-black text-on-primary transition hover:bg-primary/90 active:scale-95"
				>
					<span class="material-symbols-outlined text-[16px]">content_copy</span>
