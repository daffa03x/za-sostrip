</div>

<style>
	#share-modal[data-open='true'] [data-share-backdrop] {
		opacity: 1;
	}

	#share-modal[data-open='true'] [data-share-sheet] {
		transform: translateY(0);
	}

	@media (prefers-reduced-motion: reduce) {
		#share-modal [data-share-backdrop],
		#share-modal [data-share-sheet] {
			transition: none;
		}
	}
</style>

<script>
	const setupShareEvent = () => {
		const shareButton = document.querySelector('[data-share-event]');
		const modal = document.getElementById('share-modal');

		if (!(shareButton instanceof HTMLButtonElement) || !modal) {
			return;
		}
		if (shareButton.dataset.shareReady === 'true') {
			return;
		}
		shareButton.dataset.shareReady = 'true';

		const backdrop = modal.querySelector('[data-share-backdrop]');
		const linkInput = modal.querySelector('[data-share-link]');
		const copyBtn = modal.querySelector('[data-share-copy]');
		const socialBtns = modal.querySelectorAll('[data-share-target]');

		const getUrl = () => window.location.href;
		const getTitle = () => shareButton.dataset.shareTitle ?? document.title;
		const prefersReduced = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		// WhatsApp & Facebook punya web share intent; Instagram & TikTok tidak (di-handle terpisah).
		const buildShareUrl = (target: string, url: string, title: string): string => {
			const u = encodeURIComponent(url);
			const t = encodeURIComponent(title);
			switch (target) {
				case 'whatsapp':
					return `https://wa.me/?text=${t}%20${u}`;
				case 'facebook':
					return `https://www.facebook.com/sharer/sharer.php?u=${u}`;
				default:
					return url;
			}
		};

		const copyLink = async (url: string): Promise<boolean> => {
			if (navigator.clipboard) {
				await navigator.clipboard.writeText(url);
				return true;
			}
			if (linkInput instanceof HTMLInputElement) {
				linkInput.focus();
				linkInput.select();
				return document.execCommand('copy');
			}
			return false;
		};

		let lastFocus: Element | null = null;

		const openModal = () => {
			lastFocus = document.activeElement;
			if (linkInput instanceof HTMLInputElement) {
				linkInput.value = getUrl();
			}
			modal.classList.remove('hidden');
			document.body.style.overflow = 'hidden';
			requestAnimationFrame(() => {
				modal.dataset.open = 'true';
			});
		};

		const closeModal = () => {
			modal.dataset.open = 'false';
			document.body.style.overflow = '';
			const finish = () => modal.classList.add('hidden');
			if (prefersReduced()) {
				finish();
			} else {
				window.setTimeout(finish, 300);
			}
			if (lastFocus instanceof HTMLElement) {
				lastFocus.focus();
			}
		};

		shareButton.addEventListener('click', openModal);
		backdrop?.addEventListener('click', closeModal);
		modal.querySelectorAll('[data-share-close]').forEach((btn) => btn.addEventListener('click', closeModal));
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && modal.dataset.open === 'true') {
				closeModal();
			}
		});

		socialBtns.forEach((btn) => {
			btn.addEventListener('click', async () => {
				const target = btn.getAttribute('data-share-target') ?? '';
				const url = getUrl();

				// WhatsApp & Facebook: buka jendela share langsung.
				if (target === 'whatsapp' || target === 'facebook') {
					window.open(buildShareUrl(target, url, getTitle()), '_blank', 'noopener,noreferrer');
					return;
				}

				// Instagram & TikTok: tidak ada web share intent → salin link lalu buka aplikasinya.
				const platform = target === 'instagram' ? 'Instagram' : 'TikTok';
				const site = target === 'instagram' ? 'https://www.instagram.com/' : 'https://www.tiktok.com/';
				try {
					const ok = await copyLink(url);
					if (ok) {
						window.toast.info(`Link disalin. Tempel di ${platform} untuk membagikan.`, { title: platform });
					} else {
						window.toast.warning('Gagal menyalin link. Salin manual dari kotak di bawah.');
					}
				} catch {
					window.toast.warning('Gagal menyalin link. Salin manual dari kotak di bawah.');
				}
				window.open(site, '_blank', 'noopener,noreferrer');
			});
		});

		copyBtn?.addEventListener('click', async () => {
			try {
				if (await copyLink(getUrl())) {
					window.toast.success('Link event disalin ke clipboard.', { duration: 2500 });
				} else {
					window.toast.warning('Gagal menyalin link. Salin manual dari kotak di atas.');
				}
			} catch {
				window.toast.warning('Gagal menyalin link. Salin manual dari kotak di atas.');
			}
		});
	};

	setupShareEvent();
	document.addEventListener('astro:page-load', setupShareEvent);
</script>
