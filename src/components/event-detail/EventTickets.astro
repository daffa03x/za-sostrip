---
import type { EventDetail } from '../../data/events';

interface Props {
	event: EventDetail;
}

const { event } = Astro.props;
---

<section id="ticket-options" class="scroll-mt-md" data-reveal-scope>
	<div class="mb-md flex items-end justify-between gap-sm" data-reveal>
		<h2 class="font-headline-md text-headline-md text-on-background">Pilih tiket</h2>
		<span class="text-[11px] font-bold uppercase tracking-[0.08em] text-primary" data-bind="status">{event.status}</span>
	</div>
	<div class="space-y-sm" data-reveal-stagger data-tickets-list></div>

	<template data-tickets-tpl>
		<article class="rounded-2xl border border-outline-variant/50 bg-white p-md shadow-[0_6px_18px_-14px_rgba(80,67,78,0.35)]">
			<div class="flex items-start justify-between gap-sm">
				<div>
					<h3 class="text-lg font-black leading-tight text-on-surface" data-bind="name"></h3>
					<p class="mt-1 text-body-sm text-on-surface-variant" data-bind="description"></p>
				</div>
				<span class="shrink-0 rounded-full bg-secondary-container px-3 py-1 text-[10px] font-bold uppercase tracking-[0.08em] text-on-secondary-container" data-bind="status"></span>
			</div>
			<div class="mt-md flex items-center justify-between rounded-xl bg-surface-container-low p-sm">
				<span class="text-[11px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">Harga</span>
				<span class="text-sm font-black text-primary" data-bind="priceLabel"></span>
			</div>
		</article>
	</template>
</section>
