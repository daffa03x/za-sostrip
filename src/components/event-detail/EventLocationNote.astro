---
import type { EventDetail } from '../../data/events';

interface Props {
	event: EventDetail;
}

const { event } = Astro.props;
---

<section data-reveal-scope>
	<h2 class="mb-md font-headline-md text-headline-md text-on-background" data-reveal>Lokasi & catatan</h2>
	<div class="overflow-hidden rounded-2xl border border-outline-variant/40 bg-white shadow-[0_8px_24px_-14px_rgba(80,67,78,0.35)]" data-reveal>
		<div class="relative h-[150px] bg-gradient-to-br from-primary-container via-surface-container-low to-secondary-container">
			<div class="absolute inset-0 opacity-25" style="background-image: radial-gradient(circle at 20% 20%, white 0 8%, transparent 9%), radial-gradient(circle at 70% 55%, white 0 7%, transparent 8%);"></div>
			<div class="absolute inset-0 flex items-center justify-center">
				<div class="flex h-16 w-16 items-center justify-center rounded-full bg-white text-primary shadow-[0_12px_28px_-14px_rgba(80,67,78,0.8)]">
					<span class="material-symbols-outlined text-[34px]" data-icon="location_on">location_on</span>
				</div>
			</div>
		</div>
		<div class="p-md">
			<h3 class="text-lg font-black text-on-surface" data-bind="venue">{event.venue}</h3>
			<p class="mt-1 text-body-sm text-on-surface-variant" data-bind="location">{event.location}</p>
			<p class="mt-md rounded-xl bg-surface-container-low p-sm text-body-sm text-on-surface-variant" data-bind="impactNote">{event.impactNote}</p>
			<ul class="mt-md space-y-2" data-reveal-stagger data-notes-list></ul>

			<template data-notes-tpl>
				<li class="flex gap-sm text-body-sm text-on-surface-variant">
					<span class="material-symbols-outlined mt-0.5 text-[18px] text-primary" data-icon="info">info</span>
					<span data-bind="text"></span>
				</li>
			</template>
		</div>
	</div>
</section>
