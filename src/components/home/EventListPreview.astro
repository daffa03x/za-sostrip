---
import EventListCard from '../event/EventListCard.astro';
import { api } from '../../lib/api';
import { mapListItemToEventDetail } from '../../lib/mappers';

let previewEvents: ReturnType<typeof mapListItemToEventDetail>[] = [];
try {
	const res = await api.events.list({ per_page: 5 });
	previewEvents = res.data.map(mapListItemToEventDetail);
} catch {
	// Tampilkan kosong jika API tidak tersedia
}
---

<section class="animate-reveal delay-100" aria-labelledby="event-list-title" data-reveal-scope>
	<div class="mb-md flex items-end justify-between gap-sm">
		<h2 id="event-list-title" class="font-headline-md text-headline-md text-on-background">Sosial Trip</h2>
		<span class="text-[11px] font-bold uppercase tracking-[0.08em] text-primary">{previewEvents.length} sosial trip</span>
	</div>
	<div class="space-y-sm" data-reveal-stagger>
		{previewEvents.map((event) => <EventListCard event={event} />)}
	</div>
	<a
		class="mt-md flex min-h-12 w-full items-center justify-center rounded-full border border-outline-variant bg-white px-md text-sm font-black text-primary shadow-[0_6px_18px_-14px_rgba(80,67,78,0.35)] transition-all active:scale-[0.98] focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
		href="/events"
		data-reveal
	>
		Lihat Semua
	</a>
</section>
