---
interface Props {
	title: string;
	date: string;
	location: string;
	image: string;
	imageAlt: string;
	href: string;
	status?: string;
	badgeLines?: [string, string];
}

const { title, date, location, image, imageAlt, href, status = '', badgeLines } = Astro.props;
---

<a
	class="min-w-[280px] w-[280px] bg-white rounded-2xl shadow-[0_4px_12px_rgba(0,0,0,0.05)] border border-outline-variant/30 overflow-hidden card-hover snap-start block focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2"
	data-event-card
	data-reveal="scale"
	href={href}
	data-bind-href="href"
	aria-label={`Lihat detail ${title}`}
>
	<div class="relative bg-surface-container-low">
		<img alt={imageAlt} data-bind-alt="imageAlt" class="block w-full h-auto" src={image} data-bind-src="image" draggable="false" />
		<span class="absolute left-3 top-3 rounded-full bg-white/90 px-3 py-1 text-[10px] font-black uppercase tracking-[0.08em] text-primary shadow-sm backdrop-blur-md" data-bind="status">{status}</span>
		{
			badgeLines && (
				<div class="absolute top-3 right-3 bg-white/90 backdrop-blur-md rounded-lg shadow-sm px-2 py-1 flex items-center justify-center border border-white/20">
					<div class="text-[9px] font-black italic text-primary leading-none text-center tracking-tighter uppercase">
						{badgeLines[0]}
						<br />
						{badgeLines[1]}
					</div>
				</div>
			)
		}
	</div>
	<div class="p-4">
		<h3 class="font-bold text-lg text-on-surface leading-tight mb-3" data-bind="title">{title}</h3>
		<div class="space-y-2">
			<div class="flex items-center gap-2 text-on-surface-variant">
				<span class="material-symbols-outlined text-[18px] opacity-70" data-icon="calendar_today">calendar_today</span>
				<span class="text-xs font-medium uppercase tracking-wide" data-bind="date">{date}</span>
			</div>
			<div class="flex items-center gap-2 text-on-surface-variant">
				<span class="material-symbols-outlined text-[18px] opacity-70" data-icon="location_on">location_on</span>
				<span class="text-xs" data-bind="location">{location}</span>
			</div>
		</div>
	</div>
</a>
