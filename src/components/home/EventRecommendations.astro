---
import { events } from '../../data/events';
import EventCard from './EventCard.astro';
---

<section class="relative z-20 -mt-[165px]" data-event-carousel data-reveal-scope>
	<div class="flex justify-between items-center mb-md animate-reveal delay-200">
		<h2 class="font-headline-md text-headline-md text-white">Rekomendasi Event</h2>
		<div class="flex gap-sm">
			<button
				class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface hover:bg-primary-container hover:text-on-primary transition-colors active:scale-90 disabled:opacity-40 disabled:pointer-events-none"
				type="button"
				aria-label="Event sebelumnya"
				aria-controls="event-recommendations-list"
				data-event-scroll="previous"
			>
				<span class="material-symbols-outlined text-[20px]" data-icon="chevron_left">chevron_left</span>
			</button>
			<button
				class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface hover:bg-primary-container hover:text-on-primary transition-colors active:scale-90 disabled:opacity-40 disabled:pointer-events-none"
				type="button"
				aria-label="Event berikutnya"
				aria-controls="event-recommendations-list"
				data-event-scroll="next"
			>
				<span class="material-symbols-outlined text-[20px]" data-icon="chevron_right">chevron_right</span>
			</button>
		</div>
	</div>
	<div
		id="event-recommendations-list"
		class="flex overflow-x-auto gap-md no-scrollbar pb-sm -mx-gutter px-gutter animate-reveal delay-300 snap-x snap-mandatory scroll-px-gutter touch-pan-x cursor-grab select-none"
		data-event-list
		data-reveal-stagger
	>
		{events.map((event) => <EventCard {...event} href={`/events/${event.slug}`} />)}
	</div>
</section>

<script>
	const setupEventCarousel = () => {
		const carousel = document.querySelector('[data-event-carousel]');

		if (!(carousel instanceof HTMLElement) || carousel.dataset.carouselReady === 'true') {
			return;
		}

		const scroller = carousel.querySelector('[data-event-list]');
		const previousButton = carousel.querySelector('[data-event-scroll="previous"]');
		const nextButton = carousel.querySelector('[data-event-scroll="next"]');

		if (!(scroller instanceof HTMLElement) || !(previousButton instanceof HTMLButtonElement) || !(nextButton instanceof HTMLButtonElement)) {
			return;
		}

		carousel.dataset.carouselReady = 'true';

		const getStep = () => {
			const firstCard = scroller.querySelector('[data-event-card]');
			const cardWidth = firstCard instanceof HTMLElement ? firstCard.getBoundingClientRect().width : scroller.clientWidth * 0.8;
			const styles = window.getComputedStyle(scroller);
			const gap = Number.parseFloat(styles.columnGap || styles.gap || '0');

			return cardWidth + (Number.isNaN(gap) ? 0 : gap);
		};

		const updateControls = () => {
			const maxScrollLeft = scroller.scrollWidth - scroller.clientWidth;

			previousButton.disabled = scroller.scrollLeft <= 1;
			nextButton.disabled = scroller.scrollLeft >= maxScrollLeft - 1;
		};

		const scrollEventList = (direction) => {
			scroller.scrollBy({
				left: direction * getStep(),
				behavior: 'smooth',
			});
		};

		let animationFrame = 0;
		const scheduleControlUpdate = () => {
			window.cancelAnimationFrame(animationFrame);
			animationFrame = window.requestAnimationFrame(updateControls);
		};

		previousButton.addEventListener('click', () => scrollEventList(-1));
		nextButton.addEventListener('click', () => scrollEventList(1));
		scroller.addEventListener('scroll', scheduleControlUpdate, { passive: true });
		scroller.addEventListener('dragstart', (event) => event.preventDefault());
		window.addEventListener('resize', scheduleControlUpdate);

		let isPointerDown = false;
		let isDragging = false;
		let suppressClick = false;
		let dragStartX = 0;
		let dragStartScrollLeft = 0;

		scroller.addEventListener('pointerdown', (event) => {
			if (event.pointerType === 'touch') {
				return;
			}

			isPointerDown = true;
			dragStartX = event.clientX;
			dragStartScrollLeft = scroller.scrollLeft;
		});

		scroller.addEventListener('pointermove', (event) => {
			if (!isPointerDown) {
				return;
			}

			const dragDistance = event.clientX - dragStartX;

			if (!isDragging && Math.abs(dragDistance) < 6) {
				return;
			}

			if (!isDragging) {
				isDragging = true;
				scroller.setPointerCapture(event.pointerId);
				scroller.classList.add('cursor-grabbing');
			}

			event.preventDefault();
			scroller.scrollLeft = dragStartScrollLeft - dragDistance;
		});

		const stopDragging = (event) => {
			if (!isPointerDown && !isDragging) {
				return;
			}

			if (isDragging && scroller.hasPointerCapture(event.pointerId)) {
				scroller.releasePointerCapture(event.pointerId);
				suppressClick = true;
			}

			isPointerDown = false;
			isDragging = false;
			scroller.classList.remove('cursor-grabbing');
		};

		scroller.addEventListener(
			'click',
			(event) => {
				if (!suppressClick) {
					return;
				}

				event.preventDefault();
				event.stopPropagation();
				suppressClick = false;
			},
			true,
		);
		scroller.addEventListener('pointerup', stopDragging);
		scroller.addEventListener('pointercancel', stopDragging);
		scroller.addEventListener('lostpointercapture', () => {
			isPointerDown = false;
			isDragging = false;
			scroller.classList.remove('cursor-grabbing');
		});

		updateControls();
	};

	setupEventCarousel();
	document.addEventListener('astro:page-load', setupEventCarousel);
</script>
