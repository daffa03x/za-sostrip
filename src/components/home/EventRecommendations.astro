---
import EventCard from './EventCard.astro';
import LoadingState from '../ui/LoadingState.astro';
---

<section class="relative z-20 -mt-[165px]" data-event-carousel data-reveal-scope>
	<div class="flex justify-between items-center mb-md animate-reveal delay-200">
		<h2 class="font-headline-md text-headline-md text-white">Rekomendasi Social Trip</h2>
		<div class="flex gap-sm">
			<button
				class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface hover:bg-primary-container hover:text-on-primary transition-colors active:scale-90 disabled:opacity-40 disabled:pointer-events-none"
				type="button"
				aria-label="Event sebelumnya"
				aria-controls="event-recommendations-list"
				data-event-scroll="previous"
			>
				<span class="material-symbols-outlined text-[20px]" data-icon="chevron_left">chevron_left</span>
			</button>
			<button
				class="w-8 h-8 rounded-full bg-surface-container-highest flex items-center justify-center text-on-surface hover:bg-primary-container hover:text-on-primary transition-colors active:scale-90 disabled:opacity-40 disabled:pointer-events-none"
				type="button"
				aria-label="Event berikutnya"
				aria-controls="event-recommendations-list"
				data-event-scroll="next"
			>
				<span class="material-symbols-outlined text-[20px]" data-icon="chevron_right">chevron_right</span>
			</button>
		</div>
	</div>
	<div
		id="event-recommendations-list"
		class="flex items-start overflow-x-auto gap-md no-scrollbar pb-sm -mx-gutter px-gutter animate-reveal delay-300 snap-x snap-mandatory scroll-px-gutter touch-pan-x cursor-grab select-none"
		role="list"
		aria-label="Daftar rekomendasi event"
		data-rec-list
	>
		<LoadingState label="Memuat Social Trip..." variant="dark" size="sm" class="min-w-full py-lg" />
	</div>

	<template data-rec-tpl>
		<EventCard title="" date="" location="" image="" imageAlt="" href="#" status="" />
	</template>
</section>

<script>
	import { api } from '../../lib/api';
	import { mapListItemToEventDetail } from '../../lib/mappers';
	import { renderList } from '../../lib/csr';

	const recommendationLimit = 6;
	// Ambil lebih banyak dari limit karena sebagian akan tersaring (non-aktif / stok habis).
	const recommendationPool = 50;

	// Rekomendasi hanya event yang statusnya masih aktif (Y) DAN tiketnya belum 0.
	// Backend sudah menyediakan `is_sold_out` = (!aktif || stok<=0); saring yang belum sold out.
	const isRecommendable = (event: import('../../lib/api').EventListItem): boolean => {
		if (typeof event.is_sold_out === 'boolean') return !event.is_sold_out;
		const active = event.status === true || event.status === 1 ||
			(typeof event.status === 'string' && ['1', 'y', 'yes', 'true', 'aktif', 'active'].includes(event.status.trim().toLowerCase()));
		return active && (event.sisa_tiket ?? 0) > 0;
	};

	// Handler tombol kiri/kanan carousel. Delegasi di document sekali saja agar tetap
	// bekerja setelah konten dimuat async maupun setelah navigasi Astro (view transitions).
	const initCarouselControls = () => {
		if ((window as any).__eventScrollBound === true) return;
		(window as any).__eventScrollBound = true;

		document.addEventListener('click', (e) => {
			const target = e.target instanceof Element ? e.target.closest('[data-event-scroll]') : null;
			if (!target) return;

			const carousel = target.closest('[data-event-carousel]');
			const list = carousel?.querySelector('[data-rec-list]');
			if (!(list instanceof HTMLElement)) return;

			const firstCard = list.querySelector(':scope > *');
			const gap = 16; // gap-md
			const step = firstCard instanceof HTMLElement
				? firstCard.getBoundingClientRect().width + gap
				: 296;
			const direction = target.getAttribute('data-event-scroll') === 'previous' ? -1 : 1;

			list.scrollBy({ left: direction * step, behavior: 'smooth' });
		});
	};

	const load = async () => {
		const list = document.querySelector('[data-rec-list]');
		if (!(list instanceof HTMLElement) || list.dataset.recReady === 'true') return;
		list.dataset.recReady = 'true';

		try {
			const res = await api.events.list({ per_page: recommendationPool });
			const events = res.data
				.filter(isRecommendable)
				.slice(0, recommendationLimit)
				.map(mapListItemToEventDetail);

			if (events.length === 0) {
				list.innerHTML = '<p class="text-white/70 text-sm py-lg">Belum ada Social Trip tersedia.</p>';
				return;
			}

			renderList(
				'[data-rec-list]',
				'[data-rec-tpl]',
				events.map((event) => ({
					title: event.title,
					date: event.date,
					location: event.location,
					image: event.image,
					imageAlt: event.imageAlt,
					status: event.status,
					href: `/events/detail?slug=${encodeURIComponent(event.slug)}`,
				})),
			);
		} catch {
			list.innerHTML = '<p class="text-white/70 text-sm py-lg">Belum ada Social Trip tersedia.</p>';
		}
	};

	initCarouselControls();
	load();
	document.addEventListener('astro:page-load', () => {
		initCarouselControls();
		load();
	});
</script>
