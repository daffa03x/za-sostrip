			{
				label: 'Livin by Mandiri',
				steps: [
					'Login ke aplikasi Livin by Mandiri.',
					'Pilih <strong>Bayar</strong> &rarr; <strong>Multipayment</strong>.',
					'Cari penyedia layanan, masukkan nomor VA di atas.',
					'Konfirmasi dan selesaikan pembayaran.',
				],
			},
		],
		va_permata: [
			{
				label: 'ATM Permata / ATM Bersama',
				steps: [
					'Masukkan kartu ATM dan PIN kamu.',
					'Pilih <strong>Transaksi Lainnya</strong> &rarr; <strong>Pembayaran</strong> &rarr; <strong>Virtual Account</strong>.',
					'Masukkan nomor VA di atas.',
					'Konfirmasi detail dan selesaikan transaksi.',
				],
			},
			{
				label: 'PermataMobile X',
				steps: [
					'Login ke PermataMobile X.',
					'Pilih <strong>Bayar Tagihan</strong> &rarr; <strong>Virtual Account</strong>.',
					'Masukkan nomor VA di atas dan konfirmasi.',
				],
			},
		],
		va_cimb: [
			{
				label: 'ATM CIMB Niaga',
				steps: [
					'Masukkan kartu ATM CIMB Niaga dan PIN kamu.',
					'Pilih <strong>Pembayaran</strong> &rarr; <strong>Virtual Account</strong>.',
					'Masukkan nomor VA di atas.',
					'Konfirmasi dan selesaikan transaksi.',
				],
			},
			{
				label: 'OCTO Mobile',
				steps: [
					'Login ke OCTO Mobile.',
					'Pilih <strong>Transfer</strong> &rarr; <strong>Virtual Account</strong>.',
					'Masukkan nomor VA di atas dan konfirmasi.',
				],
			},
		],
	};

	var EW_HOWTO = {
		ewallet_gopay: [
			{
				label: 'Cara bayar GoPay',
				steps: [
					'Klik tombol <strong>Buka Aplikasi</strong> di atas atau buka Gojek.',
					'Konfirmasi pembayaran yang muncul.',
					'Masukkan PIN GoPay kamu.',
					'Pembayaran selesai, simpan bukti.',
				],
			},
		],
		ewallet_ovo: [
			{
				label: 'Cara bayar OVO',
				steps: [
					'Klik tombol <strong>Buka Aplikasi</strong> atau buka OVO.',
					'Notifikasi pembayaran akan muncul.',
					'Konfirmasi dan masukkan PIN OVO.',
				],
			},
		],
		ewallet_dana: [
			{
				label: 'Cara bayar DANA',
				steps: [
					'Klik tombol <strong>Buka Aplikasi</strong> atau buka DANA.',
					'Konfirmasi pembayaran yang masuk.',
					'Masukkan PIN DANA kamu.',
				],
			},
		],
		ewallet_shopeepay: [
			{
				label: 'Cara bayar ShopeePay',
				steps: [
					'Klik tombol <strong>Buka Aplikasi</strong> atau buka Shopee.',
					'Pilih <strong>ShopeePay</strong> dan konfirmasi pembayaran.',
					'Masukkan PIN ShopeePay kamu.',
				],
			},
		],
	};

	// ── Build accordion item HTML ─────────────────────────────────────────────
	var accordionCount = 0;
	function buildAccordion(label, stepsArray) {
		accordionCount++;
		var id = 'acc-' + accordionCount;
		var stepsHtml = stepsArray.map(function (s, i) {
			return '<li class="flex gap-sm"><span class="mt-px flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/10 text-[10px] font-black text-primary">' + (i + 1) + '</span><span class="text-body-sm text-on-surface-variant">' + s + '</span></li>';
		}).join('');
		return '<div class="overflow-hidden rounded-2xl border border-outline-variant/40 bg-white shadow-[0_6px_18px_-14px_rgba(80,67,78,0.35)]">'
			+ '<button class="flex w-full items-center justify-between px-md py-sm text-left" type="button" onclick="toggleAcc(\'' + id + '\')">'
			+ '<span class="text-sm font-black text-on-surface">' + label + '</span>'
			+ '<span class="material-symbols-outlined text-[20px] text-on-surface-variant transition-transform" id="' + id + '-chevron">expand_more</span>'
			+ '</button>'
			+ '<div id="' + id + '" class="hidden px-md pb-md">'
			+ '<ol class="space-y-sm">' + stepsHtml + '</ol>'
			+ '</div></div>';
	}

	function toggleAcc(id) {
		var panel  = document.getElementById(id);
		var chev   = document.getElementById(id + '-chevron');
		if (!panel) return;
		var isOpen = !panel.classList.contains('hidden');
		panel.classList.toggle('hidden', isOpen);
		if (chev) chev.style.transform = isOpen ? '' : 'rotate(180deg)';
	}
	window.toggleAcc = toggleAcc;

	// ── Render payment instructions ───────────────────────────────────────────
	var instructionSection = el('payment-instruction-section');

	if (method && method in VA_BANKS) {
		// VA payment
		var bank = VA_BANKS[method];
		setTxt('va-bank-label', bank.name);
		setTxt('va-number', bank.number);
		setTxt('va-total', total);

		var howToContainer = el('va-how-to');
		var steps = VA_HOWTO[method] || [];
		steps.forEach(function (item) {
			howToContainer.innerHTML += buildAccordion(item.label, item.steps);
		});

		// Open first accordion by default
		if (steps.length > 0) {
			var firstPanel  = document.getElementById('acc-1');
			var firstChevron = document.getElementById('acc-1-chevron');
			if (firstPanel)  firstPanel.classList.remove('hidden');
			if (firstChevron) firstChevron.style.transform = 'rotate(180deg)';
		}

		el('va-instruction').classList.remove('hidden');
		instructionSection.classList.remove('hidden');

		// Copy button
		var copyBtn = el('copy-va-btn');
		if (copyBtn) {
			copyBtn.addEventListener('click', function () {
				var raw = bank.number.replace(/\s/g, '');
				if (navigator.clipboard) {
					navigator.clipboard.writeText(raw).then(function () {
						copyBtn.innerHTML = '<span class="material-symbols-outlined text-[16px]">check</span> Tersalin!';
						setTimeout(function () {
							copyBtn.innerHTML = '<span class="material-symbols-outlined text-[16px]">content_copy</span> Salin';
						}, 2000);
					});
				} else {
					copyBtn.textContent = raw;
				}
			});
		}

	} else if (method && method.indexOf('ewallet_') === 0) {
		// E-Wallet payment
		var ewName = METHOD_LABELS[method] || method;
		setTxt('ew-name-label', ewName);
		setTxt('ew-total', total);

		var ewHowTo = el('ew-how-to');
		var ewSteps = EW_HOWTO[method] || [];
		ewSteps.forEach(function (item) {
			ewHowTo.innerHTML += buildAccordion(item.label, item.steps);
		});
		if (ewSteps.length > 0) {
			var ep = document.getElementById('acc-1');
			var ec = document.getElementById('acc-1-chevron');
			if (ep) ep.classList.remove('hidden');
			if (ec) ec.style.transform = 'rotate(180deg)';
		}

		el('ew-instruction').classList.remove('hidden');
		instructionSection.classList.remove('hidden');

	} else if (method === 'qris') {
		setTxt('qris-total', total);
		el('qris-instruction').classList.remove('hidden');
		instructionSection.classList.remove('hidden');

	} else if (method === 'credit_card') {
		setTxt('cc-total', total);
		el('cc-instruction').classList.remove('hidden');
		instructionSection.classList.remove('hidden');
	}

	// ── Countdown ─────────────────────────────────────────────────────────────
	var timerKey = 'payment_deadline_' + (orderId || 'demo');
	var deadline = Number(sessionStorage.getItem(timerKey));
	if (!deadline || deadline < Date.now()) {
		deadline = Date.now() + 24 * 60 * 60 * 1000;
		sessionStorage.setItem(timerKey, String(deadline));
	}
	var cdEl    = el('countdown-display');
	var timerEl = el('payment-timer-section');
	var countdownIv = null;

	function tick() {
		var rem = deadline - Date.now();
		if (rem <= 0) {
			if (cdEl) cdEl.textContent = '00:00:00';
			if (timerEl) {
				timerEl.className = timerEl.className
					.replace('border-warning/30', 'border-error/30')
					.replace('bg-warning-container/30', 'bg-error-container/20');
			}
			clearInterval(countdownIv);
			return;
		}
		var h = Math.floor(rem / 3600000).toString().padStart(2, '0');
		var m = Math.floor((rem % 3600000) / 60000).toString().padStart(2, '0');
		var s = Math.floor((rem % 60000) / 1000).toString().padStart(2, '0');
		if (cdEl) cdEl.textContent = h + ':' + m + ':' + s;
	}
	tick();
	countdownIv = setInterval(tick, 1000);

	// ── Confirm / "sudah bayar" button ────────────────────────────────────────
	var confirmBtn = el('confirm-btn');
	if (confirmBtn) {
		confirmBtn.addEventListener('click', function () {
			confirmBtn.disabled = true;
			confirmBtn.innerHTML = '<span class="material-symbols-outlined text-[18px] animate-spin">progress_activity</span> Memeriksa…';
			// In production: poll backend for status, then redirect
			setTimeout(function () {
				window.location.href = '/payment/pending?order_id=' + (orderId || 'demo');
			}, 1500);
		});
	}

	// ── CC pay button (opens Midtrans Snap) ───────────────────────────────────
	var ccBtn = el('cc-pay-btn');
	if (ccBtn) {
		ccBtn.addEventListener('click', function () {
			if (typeof window.snap === 'undefined') {
				ccBtn.textContent = 'Midtrans belum dikonfigurasi';
				return;
			}
			// Backend provides snap_token; wire up here when ready
		});
	}

	// ── E-Wallet open app button ──────────────────────────────────────────────
	var ewBtn = el('ew-open-btn');
	if (ewBtn) {
		ewBtn.addEventListener('click', function () {
			ewBtn.textContent = 'Membuka aplikasi…';
			setTimeout(function () {
				ewBtn.innerHTML = '<span class="material-symbols-outlined text-[18px]">open_in_new</span> Buka Aplikasi';
			}, 2000);
		});
	}
</script>