---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Menunggu Pembayaran | Zillenial Action">
	<div class="flex min-h-screen flex-col items-center justify-center px-gutter pb-20 pt-16 text-center">
		<!-- Icon -->
		<div class="mb-lg flex h-24 w-24 items-center justify-center rounded-full bg-warning-container shadow-[0_8px_32px_-8px_rgba(245,158,11,0.3)]">
			<span class="material-symbols-outlined text-[52px] text-warning" data-icon="schedule">schedule</span>
		</div>

		<!-- Title -->
		<h1 class="mb-sm font-headline-lg-mobile text-headline-lg-mobile text-on-background">Menunggu Pembayaran</h1>
		<p class="mb-md max-w-xs text-body-md text-on-surface-variant">
			Pesananmu sudah tercatat. Selesaikan pembayaran sebelum batas waktu agar tiketmu dikonfirmasi.
		</p>

		<!-- Order ID -->
		<div class="mb-md rounded-2xl border border-outline-variant/40 bg-white px-md py-sm shadow-[0_6px_18px_-14px_rgba(80,67,78,0.35)]">
			<p class="text-[10px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">No. Pesanan</p>
			<p class="mt-xs font-mono text-sm font-black text-on-surface" id="pending-order-id">—</p>
		</div>

		<!-- Timer -->
		<div class="mb-lg flex items-center gap-sm rounded-2xl border border-warning/30 bg-warning-container/30 px-md py-sm">
			<span class="material-symbols-outlined text-[20px] text-warning" data-icon="timer">timer</span>
			<span class="text-sm text-on-surface-variant">Batas waktu: </span>
			<span class="font-mono font-black text-warning" id="pending-countdown">—</span>
		</div>

		<!-- Instructions -->
		<div class="mb-xl w-full max-w-sm space-y-sm text-left">
			<p class="text-[11px] font-bold uppercase tracking-[0.08em] text-on-surface-variant">Cara menyelesaikan</p>
			{
				[
					{ icon: 'smartphone', label: 'Buka aplikasi mobile banking atau e-wallet kamu.' },
					{ icon: 'content_paste', label: 'Masukkan kode virtual account atau scan QR yang sudah dikirim ke email.' },
					{ icon: 'check_circle', label: 'Konfirmasi pembayaran. Tiket akan dikirim otomatis setelah berhasil.' },
				].map((step, i) => (
					<div class="flex items-start gap-sm rounded-xl bg-surface-container-low p-sm">
						<span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary text-[11px] font-black text-white">
							{i + 1}
						</span>
						<p class="text-body-sm text-on-surface">{step.label}</p>
					</div>
				))
			}
		</div>

		<!-- CTA -->
		<div class="w-full max-w-sm space-y-sm">
			<button
				class="flex w-full items-center justify-center gap-sm rounded-2xl border border-primary bg-primary-container/30 px-lg py-md text-sm font-black text-primary transition-all active:scale-[0.98] disabled:pointer-events-none disabled:opacity-60"
				type="button"
				id="check-status-btn"
			>
				<span class="material-symbols-outlined text-[18px]" data-icon="sync">sync</span>
				Cek Status Pembayaran
			</button>
			<p class="hidden text-center text-[11px] text-on-surface-variant" id="check-status-message" role="status" aria-live="polite"></p>
			<a
				class="flex w-full items-center justify-center gap-sm rounded-2xl bg-primary px-lg py-md text-sm font-black text-on-primary shadow-[0_8px_24px_-8px_rgba(125,41,127,0.35)] transition-all active:scale-[0.98]"
				href="/payment"
				id="retry-payment-link"
			>
				<span class="material-symbols-outlined text-[18px]" data-icon="payment">payment</span>
				Bayar Sekarang
			</a>
			<a
				class="flex w-full items-center justify-center gap-sm rounded-2xl border border-outline-variant bg-white px-lg py-md text-sm font-black text-on-surface transition-all active:scale-[0.98]"
				href="/events"
			>
				Lihat Event Lain
			</a>
		</div>
	</div>
</Layout>

<script>
	import { api } from '../../lib/api';

	const params = new URLSearchParams(window.location.search);
	const hashParams = new URLSearchParams(window.location.hash.replace(/^#/, ''));
	const orderIdParam = params.get('order_id')?.trim() ?? '';
	const accessToken =
		hashParams.get('token')?.trim() ??
		params.get('token')?.trim() ??
		sessionStorage.getItem(`payment_access_token_${orderIdParam}`) ??
		'';
	const orderId = orderIdParam || '—';
	if (orderIdParam && accessToken) {
		sessionStorage.setItem(`payment_access_token_${orderIdParam}`, accessToken);
	}
	const el = document.getElementById('pending-order-id');
	if (el) el.textContent = orderId;

	// Retry link preserves order_id
	const retryLink = document.getElementById('retry-payment-link');
	if (retryLink instanceof HTMLAnchorElement && orderIdParam) {
		const retryParams = new URLSearchParams({ order_id: orderIdParam });
		const retryHash = accessToken ? `#token=${encodeURIComponent(accessToken)}` : '';
		retryLink.href = `/payment?${retryParams.toString()}${retryHash}`;
	}

	const paymentPath = (path) => {
		const paymentParams = new URLSearchParams({ order_id: orderIdParam });
		const paymentHash = accessToken ? `#token=${encodeURIComponent(accessToken)}` : '';
		return `${path}?${paymentParams.toString()}${paymentHash}`;
	};

	const checkStatusBtn = document.getElementById('check-status-btn');
	const checkStatusMessage = document.getElementById('check-status-message');
	const checkStatusDefaultHtml = '<span class="material-symbols-outlined text-[18px]" data-icon="sync">sync</span>Cek Status Pembayaran';

	const setCheckStatusMessage = (message, tone = 'neutral') => {
		if (!checkStatusMessage) return;
		checkStatusMessage.textContent = message;
		checkStatusMessage.classList.remove('hidden', 'text-on-surface-variant', 'text-error', 'text-primary');
		checkStatusMessage.classList.add(tone === 'error' ? 'text-error' : tone === 'success' ? 'text-primary' : 'text-on-surface-variant');
	};

	if (checkStatusBtn instanceof HTMLButtonElement) {
		if (!orderIdParam) {
			checkStatusBtn.disabled = true;
			setCheckStatusMessage('No. pesanan tidak ditemukan.');
		}

		checkStatusBtn.addEventListener('click', async () => {
			if (!orderIdParam) return;

			let isRedirecting = false;
			checkStatusBtn.disabled = true;
			checkStatusBtn.setAttribute('aria-busy', 'true');
			checkStatusBtn.innerHTML = '<span class="inline-block h-4 w-4 animate-spin rounded-full border-2 border-current border-r-transparent" aria-hidden="true"></span><span>Memeriksa...</span>';
			setCheckStatusMessage('Memeriksa status pembayaran...');

			try {
				const res = await api.transaksi.status(orderIdParam, accessToken);
				const status = res.data.status_pembayaran;

				if (status === 'Success') {
					isRedirecting = true;
					window.location.href = `/payment/success?order_id=${encodeURIComponent(orderIdParam)}`;
					return;
				}

				if (status === 'Failed') {
					isRedirecting = true;
					window.location.href = paymentPath('/payment/failed');
					return;
				}

				setCheckStatusMessage('Pembayaran masih menunggu konfirmasi otomatis.');
			} catch {
				setCheckStatusMessage('Belum bisa cek status. Coba lagi sebentar.', 'error');
			} finally {
				if (!isRedirecting) {
					checkStatusBtn.disabled = false;
					checkStatusBtn.removeAttribute('aria-busy');
					checkStatusBtn.innerHTML = checkStatusDefaultHtml;
				}
			}
		});
	}

	// Countdown
	const storageKey = `payment_deadline_${orderId}`;
	const deadline = Number(sessionStorage.getItem(storageKey)) || (Date.now() + 24 * 60 * 60 * 1000);
	const countdownEl = document.getElementById('pending-countdown');
	const tick = () => {
		const remaining = deadline - Date.now();
		if (remaining <= 0) { if (countdownEl) countdownEl.textContent = 'Kadaluarsa'; return; }
		const h = Math.floor(remaining / 3600000).toString().padStart(2, '0');
		const m = Math.floor((remaining % 3600000) / 60000).toString().padStart(2, '0');
		const s = Math.floor((remaining % 60000) / 1000).toString().padStart(2, '0');
		if (countdownEl) countdownEl.textContent = `${h}:${m}:${s}`;
	};
	tick();
	setInterval(tick, 1000);
</script>
