---
import BottomNav from '../components/BottomNav.astro';
import Toast from '../components/ui/Toast.astro';
import '../styles/global.css';

interface Props {
	title?: string;
}

const { title = 'Beyond the Game - Home' } = Astro.props;
---

<!doctype html>
<html class="scroll-smooth" lang="id">
	<head>
		<meta charset="utf-8" />
		<meta content="width=device-width, initial-scale=1.0" name="viewport" />
		<title>{title}</title>
		<link href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:ital,wght@0,400;0,600;0,700;0,900;1,900&family=Inter:wght@400;600&display=swap" rel="stylesheet" />
		<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
		<script is:inline>
			document.documentElement.classList.add('motion-ready');
		</script>
		<style is:global>
			.no-scrollbar::-webkit-scrollbar {
				display: none;
			}

			.no-scrollbar {
				-ms-overflow-style: none;
				scrollbar-width: none;
			}

			@keyframes revealUp {
				from {
					opacity: 0;
					transform: translate3d(0, 18px, 0) scale(0.98);
				}

				to {
					opacity: 1;
					transform: translate3d(0, 0, 0) scale(1);
				}
			}

			@keyframes softGlow {
				from {
					box-shadow: 0 10px 24px -18px rgba(125, 41, 127, 0.35);
				}

				to {
					box-shadow: 0 16px 30px -18px rgba(125, 41, 127, 0.6);
				}
			}

			.animate-reveal {
				opacity: 0;
				animation: revealUp 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
				will-change: opacity, transform;
			}

			.delay-100 {
				animation-delay: 100ms;
			}

			.delay-200 {
				animation-delay: 200ms;
			}

			.delay-300 {
				animation-delay: 300ms;
			}

			.delay-400 {
				animation-delay: 400ms;
			}

			.delay-500 {
				animation-delay: 500ms;
			}

			.motion-ready [data-reveal] {
				opacity: 0;
				transform: translate3d(0, 18px, 0) scale(0.985);
				transition:
					opacity 560ms cubic-bezier(0.2, 0.8, 0.2, 1),
					transform 560ms cubic-bezier(0.2, 0.8, 0.2, 1);
				transition-delay: var(--reveal-delay, 0ms);
				will-change: opacity, transform;
			}

			.motion-ready [data-reveal='fade'] {
				transform: none;
			}

			.motion-ready [data-reveal='scale'] {
				transform: scale(0.96);
			}

			.motion-ready [data-reveal].is-visible {
				opacity: 1;
				transform: translate3d(0, 0, 0) scale(1);
			}

			[data-reveal-stagger] > [data-reveal]:nth-child(2) {
				--reveal-delay: 70ms;
			}

			[data-reveal-stagger] > [data-reveal]:nth-child(3) {
				--reveal-delay: 140ms;
			}

			[data-reveal-stagger] > [data-reveal]:nth-child(4) {
				--reveal-delay: 210ms;
			}

			[data-reveal-stagger] > [data-reveal]:nth-child(5) {
				--reveal-delay: 280ms;
			}

			[data-reveal-stagger] > [data-reveal]:nth-child(n + 6) {
				--reveal-delay: 320ms;
			}

			.card-hover {
				transition:
					transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
					box-shadow 220ms cubic-bezier(0.2, 0.8, 0.2, 1),
					border-color 220ms ease;
				will-change: transform;
			}

			.card-hover:active,
			.card-hover:hover {
				transform: translateY(-3px) scale(1.015);
				box-shadow: 0 14px 28px -16px rgba(125, 41, 127, 0.45);
			}

			.category-hover {
				transition: all 0.2s ease-out;
			}

			.category-hover:active {
				transform: scale(0.92);
				background-color: var(--surface-container-low);
			}

			.nav-item-active:active {
				transform: scale(0.85);
				transition: transform 0.1s ease;
			}

			.cta-glow {
				animation: softGlow 2.6s ease-in-out infinite alternate;
			}

			@media (prefers-reduced-motion: reduce) {
				*,
				*::before,
				*::after {
					scroll-behavior: auto !important;
					animation-duration: 0.01ms !important;
					animation-iteration-count: 1 !important;
					transition-duration: 0.01ms !important;
				}

				.animate-reveal,
				.motion-ready [data-reveal] {
					opacity: 1 !important;
					transform: none !important;
					animation: none !important;
					transition: none !important;
				}

				.card-hover:active,
				.card-hover:hover,
				.category-hover:active,
				.nav-item-active:active {
					transform: none;
				}
			}
		</style>
	</head>
	<body class="bg-surface-container-highest text-on-background font-body-md min-h-screen">
		<Toast />
		<div class="relative mx-auto min-h-screen max-w-[430px] overflow-x-hidden bg-background pb-8 shadow-[0_0_40px_rgba(80,67,78,0.12)]">
			<slot />
			{/* <BottomNav /> */}
		</div>
		<script is:inline>
			const setupMotionReveal = () => {
				const items = Array.from(document.querySelectorAll('[data-reveal]')).filter((item) => item instanceof HTMLElement);

				if (!items.length) {
					return;
				}

				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

				if (prefersReducedMotion || !('IntersectionObserver' in window)) {
					items.forEach((item) => item.classList.add('is-visible'));
					return;
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) {
								return;
							}

							entry.target.classList.add('is-visible');
							observer.unobserve(entry.target);
						});
					},
					{
						rootMargin: '0px 0px -8% 0px',
						threshold: 0.12,
					},
				);

				items.forEach((item) => {
					if (item.dataset.revealReady === 'true') {
						return;
					}

					item.dataset.revealReady = 'true';
					observer.observe(item);
				});
			};

			setupMotionReveal();
			document.addEventListener('astro:page-load', setupMotionReveal);
		</script>
	</body>
</html>
